{
  "name": "rock-magnus-cli",
  "version": "0.1.0",
  "description": "CLI for interacting with Rock RMS via the Magnus API",
  "type": "module",
  "bin": {
    "magnus": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "rock-rms",
    "magnus",
    "cli"
  ],
  "license": "MIT",
  "author": "Bradley Erb",
  "repository": {
    "type": "git",
    "url": "https://github.com/bradleyerb/rock-magnus-cli.git"
  },
  "homepage": "https://github.com/bradleyerb/rock-magnus-cli",
  "bugs": {
    "url": "https://github.com/bradleyerb/rock-magnus-cli/issues"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "form-data": "^4.0.5",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  }
}
